// ===== PIPE GENERATION =====
function spawnPipe() {
  const W = getW(), H = getH();
  const gap = Math.max(130, PIPE_GAP_BASE - Math.floor(score / 10) * 5);
  const minY = H * 0.15;
  const maxY = H * 0.75 - gap;
  const gapY = minY + Math.random() * (maxY - minY);
  pipes.push({
    x: W + PIPE_WIDTH,
    gapY: gapY,
    gap: gap,
    passed: false,
    hue: 120 + score * 5,
  });
}

// ===== COIN GENERATION =====
function spawnCoin() {
  const W = getW(), H = getH();
  coins.push({
    x: W + 20,
    y: H * 0.2 + Math.random() * H * 0.6,
    collected: false,
    pulse: Math.random() * Math.PI * 2,
    rot: 0,
  });
}

// ===== POWERUP GENERATION =====
const POWERUP_TYPES = [
  { type:'shield',     emoji:'🛡️', color:'#00BFFF', label:'SHIELD' },
  { type:'slowmo',     emoji:'🐌', color:'#9B59B6', label:'SLOW-MO' },
  { type:'invincible', emoji:'⚡', color:'#FFD700', label:'INVINCIBLE' },
  { type:'magnet',     emoji:'🧲', color:'#E74C3C', label:'MAGNET' },
  { type:'life',       emoji:'❤️', color:'#FF6B9D', label:'+LIFE' },
];
function spawnPowerup() {
  const W = getW(), H = getH();
  const t = POWERUP_TYPES[Math.floor(Math.random() * POWERUP_TYPES.length)];
  powerupItems.push({ x: W + 20, y: H * 0.2 + Math.random() * H * 0.6, ...t, pulse: 0 });
}

// ===== PARTICLES =====
function spawnParticles(x, y, color, count, type='burst') {
  for (let i = 0; i < count; i++) {
    const angle = (Math.PI * 2 * i) / count + Math.random() * 0.5;
    const speed = 1 + Math.random() * 5;
    particles.push({
      x, y,
      vx: Math.cos(angle) * speed,
      vy: Math.sin(angle) * speed - (type==='up'?3:0),
      alpha: 1,
      color,
      size: 3 + Math.random() * 5,
      life: 1,
      decay: 0.02 + Math.random() * 0.03,
    });
  }
}

// ===== COLLISION =====
function circleRect(cx, cy, cr, rx, ry, rw, rh) {
  const nearX = Math.max(rx, Math.min(cx, rx + rw));
  const nearY = Math.max(ry, Math.min(cy, ry + rh));
  const dx = cx - nearX, dy = cy - nearY;
  return dx * dx + dy * dy < cr * cr;
}

// ===== APPLY POWERUP =====
function applyPowerup(type) {
  const duration = 5000;
  if (type === 'life') {
    lives = Math.min(lives + 1, 3);
    maxLives = Math.max(maxLives, lives);
    spawnParticles(bird.x, bird.y, '#FF6B9D', 20);
    updateLivesUI();
    return;
  }
  activePowerups[type] = true;
  if (powerupTimers[type]) clearTimeout(powerupTimers[type]);
  powerupTimers[type] = setTimeout(() => {
    activePowerups[type] = false;
    updatePowerupUI();
  }, duration);
  updatePowerupUI();
  spawnParticles(bird.x, bird.y, POWERUP_TYPES.find(p=>p.type===type)?.color||'#fff', 20);
}

function updatePowerupUI() {
  const div = document.getElementById('powerupDisplay');
  div.innerHTML = '';
  for (const [type, active] of Object.entries(activePowerups)) {
    if (active) {
      const info = POWERUP_TYPES.find(p=>p.type===type);
      if (!info) continue;
      const el = document.createElement('div');
      el.className = 'powerup-indicator';
      el.style.borderColor = info.color;
      el.innerHTML = `${info.emoji} ${info.label}`;
      div.appendChild(el);
    }
  }
}

function updateLivesUI() {
  const div = document.getElementById('livesDisplay');
  div.innerHTML = '';
  for (let i = 0; i < lives; i++) {
    const span = document.createElement('span');
    span.textContent = '❤️';
    div.appendChild(span);
  }
}

// ===== BACKGROUND =====
let bgOffset = 0;
let cloudOffset = 0;
let groundOffset = 0;

function drawBackground() {
  const W = getW(), H = getH();
  const skyGrad = ctx.createLinearGradient(0, 0, 0, H);
  const t = (score % 30) / 30;
  const r = Math.floor(lerp(30, 10, t));
  const g = Math.floor(lerp(100, 20, t));
  const b = Math.floor(lerp(180, 60, t));
  skyGrad.addColorStop(0, `rgb(${r},${g},${b})`);
  skyGrad.addColorStop(1, `rgb(${Math.floor(r*0.3)},${Math.floor(g*0.3)},${Math.floor(b*0.3)})`);
  ctx.fillStyle = skyGrad;
  ctx.fillRect(0, 0, W, H);

  ctx.fillStyle = 'rgba(255,255,255,0.6)';
  for (let i = 0; i < 40; i++) {
    const sx = ((i * 137.5 + bgOffset * 0.1) % W);
    const sy = (i * 73.1) % (H * 0.7);
    ctx.beginPath();
    ctx.arc(sx, sy, 1 + (i%3)*0.5, 0, Math.PI*2);
    ctx.fill();
  }

  ctx.fillStyle = 'rgba(255,255,255,0.12)';
  for (let i = 0; i < 4; i++) {
    const cx = ((i * W / 3 - cloudOffset * 0.5) % (W + 200)) - 100;
    const cy = H * (0.1 + i * 0.08);
    drawCloud(cx, cy, 60 + i * 20);
  }

  const gH = Math.max(50, H * 0.08);
  const groundGrad = ctx.createLinearGradient(0, H - gH, 0, H);
  groundGrad.addColorStop(0, '#2d5a1b');
  groundGrad.addColorStop(0.3, '#3d7a25');
  groundGrad.addColorStop(1, '#1a3a0d');
  ctx.fillStyle = groundGrad;
  ctx.fillRect(0, H - gH, W, gH);

  ctx.fillStyle = 'rgba(255,255,255,0.05)';
  const stripeW = 40;
  for (let i = 0; i < W / stripeW + 2; i++) {
    const sx = ((i * stripeW - groundOffset) % (W + stripeW)) - stripeW;
    ctx.fillRect(sx, H - gH, stripeW * 0.5, gH);
  }
}

function drawCloud(x, y, size) {
  ctx.beginPath();
  ctx.arc(x, y, size * 0.5, 0, Math.PI*2);
  ctx.arc(x + size*0.4, y - size*0.1, size*0.35, 0, Math.PI*2);
  ctx.arc(x + size*0.7, y, size*0.4, 0, Math.PI*2);
  ctx.arc(x + size*0.3, y + size*0.15, size*0.45, 0, Math.PI*2);
  ctx.fill();
}

function lerp(a, b, t) { return a + (b-a)*t; }

// ===== DRAW PIPES =====
function drawPipes() {
  const H = getH();
  pipes.forEach(p => {
    const groundH = Math.max(50, H * 0.08);
    const topHeight = p.gapY;
    const bottomY = p.gapY + p.gap;
    const bottomHeight = H - groundH - bottomY;
    const color = `hsl(${p.hue},70%,35%)`;
    drawPipe(p.x, 0, PIPE_WIDTH, topHeight, color, true);
    drawPipe(p.x, bottomY, PIPE_WIDTH, bottomHeight, color, false);
  });
}

function drawPipe(x, y, w, h, color, isTop) {
  const capH = 22, capExtra = 8;
  ctx.save();
  ctx.shadowBlur = 8;
  ctx.shadowColor = 'rgba(0,0,0,0.4)';

  const grad = ctx.createLinearGradient(x, 0, x + w, 0);
  grad.addColorStop(0, 'rgba(0,0,0,0.3)');
  grad.addColorStop(0.2, 'rgba(255,255,255,0.2)');
  grad.addColorStop(1, 'rgba(0,0,0,0.2)');

  ctx.fillStyle = color;
  if (isTop) {
    ctx.fillRect(x, y, w, h - capH);
    ctx.fillStyle = shiftHue(color, 20);
    ctx.fillRect(x - capExtra, y + h - capH, w + capExtra*2, capH);
  } else {
    ctx.fillRect(x, y + capH, w, h - capH);
    ctx.fillStyle = shiftHue(color, 20);
    ctx.fillRect(x - capExtra, y, w + capExtra*2, capH);
  }

  // Shine overlay
  ctx.fillStyle = 'rgba(255,255,255,0.12)';
  if (isTop) {
    ctx.fillRect(x + w*0.15, y, w*0.2, h - capH);
  } else {
    ctx.fillRect(x + w*0.15, y + capH, w*0.2, h - capH);
  }

  ctx.strokeStyle = 'rgba(0,0,0,0.4)';
  ctx.lineWidth = 2;
  if (isTop) {
    ctx.strokeRect(x, y, w, h - capH);
    ctx.strokeRect(x - capExtra, y + h - capH, w + capExtra*2, capH);
  } else {
    ctx.strokeRect(x, y + capH, w, h - capH);
    ctx.strokeRect(x - capExtra, y, w + capExtra*2, capH);
  }
  ctx.restore();
}

function shiftHue(hslStr, lightShift) {
  // Just brighten slightly
  return hslStr.replace(/(\d+)%\)/, (m, l) => `${Math.min(100, parseInt(l) + lightShift)}%)`);
}

// ===== DRAW COINS =====
function drawCoins() {
  coins.forEach(c => {
    if (c.collected) return;
    c.pulse += 0.1;
    c.rot = (c.rot || 0) + 0.05;
    const s = 1 + Math.sin(c.pulse) * 0.15;
    ctx.save();
    ctx.translate(c.x, c.y);
    ctx.scale(s, 1);
    ctx.shadowBlur = 18;
    ctx.shadowColor = '#FFD700';
    // Draw a proper coin
    const r = COIN_RADIUS;
    const cGrad = ctx.createRadialGradient(-r*0.2, -r*0.2, r*0.1, 0, 0, r);
    cGrad.addColorStop(0, '#FFF4AA');
    cGrad.addColorStop(0.5, '#FFD700');
    cGrad.addColorStop(1, '#AA7700');
    ctx.fillStyle = cGrad;
    ctx.beginPath();
    ctx.arc(0, 0, r, 0, Math.PI*2);
    ctx.fill();
    ctx.strokeStyle = '#AA7700';
    ctx.lineWidth = 1.5;
    ctx.stroke();
    // Coin symbol
    ctx.shadowBlur = 0;
    ctx.fillStyle = '#AA7700';
    ctx.font = `bold ${r * 1.1}px Arial`;
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText('$', 0, 1);
    ctx.restore();
  });
}

// ===== DRAW POWERUPS =====
function drawPowerups() {
  powerupItems.forEach(p => {
    p.pulse += 0.08;
    const s = 1 + Math.sin(p.pulse) * 0.2;
    ctx.save();
    ctx.translate(p.x, p.y);
    ctx.scale(s, s);
    ctx.shadowBlur = 25;
    ctx.shadowColor = p.color;
    // Background orb
    const orbGrad = ctx.createRadialGradient(0, 0, 2, 0, 0, 22);
    orbGrad.addColorStop(0, p.color + 'CC');
    orbGrad.addColorStop(1, p.color + '33');
    ctx.fillStyle = orbGrad;
    ctx.beginPath();
    ctx.arc(0, 0, 22, 0, Math.PI*2);
    ctx.fill();
    ctx.strokeStyle = p.color;
    ctx.lineWidth = 2.5;
    ctx.stroke();
    ctx.shadowBlur = 0;
    ctx.font = '22px serif';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText(p.emoji, 0, 0);
    ctx.restore();
  });
}

// ===== DRAW PARTICLES =====
function drawParticles() {
  pCtx.clearRect(0, 0, pCanvas.width, pCanvas.height);
  particles.forEach(p => {
    pCtx.save();
    pCtx.globalAlpha = p.alpha;
    pCtx.fillStyle = p.color;
    pCtx.shadowBlur = 8;
    pCtx.shadowColor = p.color;
    pCtx.beginPath();
    pCtx.arc(p.x, p.y, p.size, 0, Math.PI*2);
    pCtx.fill();
    pCtx.restore();
  });
}

// ===== SCORE POPUPS =====
let scorePopups = [];
function addScorePopup(x, y, text, color) {
  scorePopups.push({ x, y, text, color, alpha: 1, vy: -2, life: 60 });
}
function drawScorePopups() {
  scorePopups.forEach(p => {
    ctx.save();
    ctx.globalAlpha = p.alpha;
    ctx.fillStyle = p.color;
    ctx.font = `bold ${clamp(18, 4.5 * window.innerWidth / 100, 28)}px Arial`;
    ctx.textAlign = 'center';
    ctx.shadowBlur = 10;
    ctx.shadowColor = p.color;
    ctx.fillText(p.text, p.x, p.y);
    ctx.restore();
  });
}
function clamp(min, val, max) { return Math.min(max, Math.max(min, val)); }

// ===== UPDATE PARTICLES =====
function updateParticles() {
  particles = particles.filter(p => p.life > 0);
  particles.forEach(p => {
    p.x += p.vx; p.y += p.vy; p.vy += 0.15;
    p.life--; p.alpha = p.life / 60; p.size *= 0.97;
  });
  scorePopups = scorePopups.filter(p => p.life > 0);
  scorePopups.forEach(p => { p.y += p.vy; p.life--; p.alpha = p.life / 60; });
}

// ===== FLAP =====
function doFlap() {
  if (gameState !== 'playing') return;
  bird.vy = FLAP_STRENGTH;
  bird.angle = -0.35;
  wingPhase = 0; // reset wing to flap
  spawnParticles(bird.x - 15, bird.y + 5, '#fff', 4);
}

// ===== DEATH =====
function handleDeath() {
  if (activePowerups.shield) {
    activePowerups.shield = false;
    clearTimeout(powerupTimers.shield);
    updatePowerupUI();
    bird.flash = 30;
    spawnParticles(bird.x, bird.y, '#00BFFF', 25);
    return;
  }
  if (activePowerups.invincible) return;

  lives--;
  updateLivesUI();

  if (lives <= 0) {
    triggerGameOver();
  } else {
    bird.flash = 60;
    activePowerups.invincible = true;
    clearTimeout(powerupTimers.invincible);
    powerupTimers.invincible = setTimeout(() => {
      activePowerups.invincible = false;
      updatePowerupUI();
    }, 2500);
    updatePowerupUI();
    spawnParticles(bird.x, bird.y, '#FF4444', 20);
  }
}

function triggerGameOver() {
  gameState = 'gameover';
  spawnParticles(bird.x, bird.y, '#FF4444', 40);

  gameData = getData();
  gameData.coins += Math.floor(score * 0.5);
  if (score > gameData.best) { gameData.best = score; isNewBest = true; }
  else { isNewBest = false; }
  gameData.scores = gameData.scores || [];
  gameData.scores.push({ score, date: Date.now() });
  gameData.scores.sort((a,b) => b.score - a.score);
  gameData.scores = gameData.scores.slice(0, 10);
  saveData(gameData);

  document.getElementById('goScore').textContent = score;
  const bestEl = document.getElementById('goBest');
  bestEl.textContent = `Best: ${gameData.best}`;
  if (isNewBest) { bestEl.textContent += ' 🎉 NEW BEST!'; bestEl.classList.add('new-best'); }
  else { bestEl.classList.remove('new-best'); }
  document.getElementById('hud').style.display = 'none';
  showPanel('gameOverPanel');
}

// ===== MAIN GAME LOOP =====
function gameLoop() {
  if (gameState !== 'playing') {
    if (gameState === 'menu') drawMenuBackground();
    return;
  }

  frame++;
  bgOffset += 1;
  cloudOffset += 0.3;
  groundOffset += (activePowerups.slowmo ? 1 : 2) * gameSpeed;
  wingPhase += activePowerups.invincible ? 0.12 : 0.06;

  const W = getW(), H = getH();
  const groundH = Math.max(50, H * 0.08);
  const speed = (activePowerups.slowmo ? 0.5 : 1) * gameSpeed;

  gameSpeed = 1 + Math.floor(score / 10) * 0.08;

  if (pendingFlap) { doFlap(); pendingFlap = false; }

  bird.vy += GRAVITY;
  bird.vy = Math.min(bird.vy, 12);
  bird.y += bird.vy;
  bird.angle = Math.min(bird.angle + 0.04, 0.5);
  bird.scale = 1 + Math.abs(Math.sin(frame * 0.1)) * 0.05;
  if (bird.flash > 0) bird.flash--;

  if (bird.y - BIRD_RADIUS < 0) { bird.y = BIRD_RADIUS; bird.vy = 1; }

  if (bird.y + BIRD_RADIUS > H - groundH) {
    if (!activePowerups.invincible) handleDeath();
    else { bird.y = H - groundH - BIRD_RADIUS; bird.vy = FLAP_STRENGTH * 0.5; }
    if (gameState !== 'playing') return;
  }

  if (frame - lastPipeFrame > Math.max(60, 120 - score * 2)) { spawnPipe(); lastPipeFrame = frame; }
  if (frame - lastCoinFrame > 80) { if (Math.random() < 0.6) spawnCoin(); lastCoinFrame = frame; }
  if (frame - lastPUFrame > 300) { if (Math.random() < 0.4) spawnPowerup(); lastPUFrame = frame; }

  for (let i = pipes.length - 1; i >= 0; i--) {
    const p = pipes[i];
    p.x -= PIPE_SPEED_BASE * speed;
    if (p.x + PIPE_WIDTH < 0) { pipes.splice(i, 1); continue; }

    if (!p.passed && p.x + PIPE_WIDTH < bird.x - BIRD_RADIUS) {
      p.passed = true;
      score++;
      document.getElementById('scoreDisplay').textContent = score;
      addScorePopup(bird.x, bird.y - 40, '+1', '#FFD700');
      spawnParticles(bird.x, bird.y, '#FFD700', 6);
    }

    if (!activePowerups.invincible) {
      const topHeight = p.gapY;
      const bottomY = p.gapY + p.gap;
      const bottomHeight = H - groundH - bottomY;
      const hitTop = circleRect(bird.x, bird.y, BIRD_RADIUS * 0.72, p.x - 8, 0, PIPE_WIDTH + 16, topHeight);
      const hitBottom = circleRect(bird.x, bird.y, BIRD_RADIUS * 0.72, p.x - 8, bottomY, PIPE_WIDTH + 16, bottomHeight);
      if (hitTop || hitBottom) { handleDeath(); if (gameState !== 'playing') return; }
    }
  }

  for (let i = coins.length - 1; i >= 0; i--) {
    const c = coins[i];
    c.x -= PIPE_SPEED_BASE * speed * 0.8;
    if (c.x < -30) { coins.splice(i, 1); continue; }
    if (c.collected) continue;
    if (activePowerups.magnet) {
      const dx = bird.x - c.x, dy = bird.y - c.y;
      const dist = Math.sqrt(dx*dx + dy*dy);
      if (dist < 150) { c.x += dx * 0.12; c.y += dy * 0.12; }
    }
    const dx = bird.x - c.x, dy = bird.y - c.y;
    if (dx*dx + dy*dy < (BIRD_RADIUS + COIN_RADIUS) ** 2) {
      c.collected = true;
      gameData.coins++;
      spawnParticles(c.x, c.y, '#FFD700', 12);
      addScorePopup(c.x, c.y, '+COIN', '#FFD700');
    }
  }

  for (let i = powerupItems.length - 1; i >= 0; i--) {
    const p = powerupItems[i];
    p.x -= PIPE_SPEED_BASE * speed * 0.8;
    if (p.x < -30) { powerupItems.splice(i, 1); continue; }
    const dx = bird.x - p.x, dy = bird.y - p.y;
    if (dx*dx + dy*dy < (BIRD_RADIUS + 22)**2) {
      applyPowerup(p.type);
      addScorePopup(p.x, p.y, p.label, p.color);
      powerupItems.splice(i, 1);
    }
  }

  updateParticles();

  ctx.clearRect(0, 0, W, H);
  drawBackground();
  drawPipes();
  drawCoins();
  drawPowerups();

  // Draw the bird
  const currentSkin = SKINS.find(s => s.id === gameData.selectedSkin) || SKINS[0];
  drawBirdGraphic(
    ctx, currentSkin,
    bird.x, bird.y,
    BIRD_RADIUS,
    wingPhase,
    bird.angle,
    bird.flash > 0,
    activePowerups.shield,
    activePowerups.invincible
  );

  drawScorePopups();
  drawParticles();

  animFrame = requestAnimationFrame(gameLoop);
}

// ===== MENU BACKGROUND =====
let menuFrame = 0;
function drawMenuBackground() {
  const W = getW(), H = getH();
  menuFrame++;
  bgOffset += 0.3;
  cloudOffset += 0.1;
  groundOffset += 0.5;
  ctx.clearRect(0, 0, W, H);
  drawBackground();
  const demoPhase = (menuFrame * 0.5) % (W + 200);
  const gapY = H * 0.35;
  const gap = 200;
  drawPipe(W - demoPhase + 100, 0, PIPE_WIDTH, gapY, 'hsl(120,70%,35%)', true);
  drawPipe(W - demoPhase + 100, gapY + gap, PIPE_WIDTH, H - gapY - gap - 50, 'hsl(120,70%,35%)', false);
  drawPipe(W - demoPhase + 450, 0, PIPE_WIDTH, gapY - 40, 'hsl(120,70%,35%)', true);
  drawPipe(W - demoPhase + 450, gapY - 40 + gap + 20, PIPE_WIDTH, H - (gapY-40+gap+20) - 50, 'hsl(120,70%,35%)', false);
  if (gameState === 'menu') requestAnimationFrame(drawMenuBackground);
}

// ===== PANELS =====
function showPanel(id) {
  const panels = ['menuPanel','gameOverPanel','shopPanel','lbPanel'];
  panels.forEach(p => {
    const el = document.getElementById(p);
    if (p === id) el.classList.remove('hidden');
    else el.classList.add('hidden');
  });
}

function showMenu() {
  gameState = 'menu';
  gameData = getData();
  document.getElementById('menuBest').textContent = gameData.best;
  document.getElementById('menuCoins').textContent = gameData.coins;
  document.getElementById('hud').style.display = 'none';
  showPanel('menuPanel');
  cancelAnimationFrame(animFrame);
  cancelAnimationFrame(menuBirdAnimFrame);
  animateMenuBird();
  drawMenuBackground();
}

function startGame() {
  cancelAnimationFrame(animFrame);
  cancelAnimationFrame(menuBirdAnimFrame);
  gameState = 'playing';
  gameData = getData();
  initGame();
  document.querySelectorAll('.panel').forEach(p => p.classList.add('hidden'));
  document.getElementById('hud').style.display = 'block';
  gameLoop();
}

function showShop() {
  gameData = getData();
  document.getElementById('shopCoins').textContent = gameData.coins;
  buildSkinsGrid();
  showPanel('shopPanel');
}

function buildSkinsGrid() {
  const grid = document.getElementById('skinsGrid');
  grid.innerHTML = '';
  SKINS.forEach(skin => {
    const owned = gameData.owned.includes(skin.id);
    const selected = gameData.selectedSkin === skin.id;
    const card = document.createElement('div');
    card.className = `skin-card${selected?' selected':''}${!owned?' locked':''}`;

    // Mini canvas for skin preview
    const previewCanvas = document.createElement('canvas');
    previewCanvas.width = 70;
    previewCanvas.height = 70;
    previewCanvas.className = 'skin-canvas';
    const pctx = previewCanvas.getContext('2d');
    drawBirdGraphic(pctx, skin, 35, 38, 20, 0.25, -0.05, false, false, false);

    card.appendChild(previewCanvas);

    const nameDiv = document.createElement('div');
    nameDiv.className = 'skin-name';
    nameDiv.textContent = skin.name;
    card.appendChild(nameDiv);

    const priceDiv = document.createElement('div');
    priceDiv.className = 'skin-price';
    priceDiv.textContent = owned ? (selected ? '✓ Selected' : 'Tap to equip') : `🪙 ${skin.price}`;
    card.appendChild(priceDiv);

    card.addEventListener('click', () => {
      if (owned) {
        gameData.selectedSkin = skin.id;
        saveData(gameData);
        buildSkinsGrid();
        cancelAnimationFrame(menuBirdAnimFrame);
        animateMenuBird();
      } else {
        if (gameData.coins >= skin.price) {
          gameData.coins -= skin.price;
          gameData.owned.push(skin.id);
          gameData.selectedSkin = skin.id;
          saveData(gameData);
          document.getElementById('shopCoins').textContent = gameData.coins;
          buildSkinsGrid();
        } else {
          card.style.borderColor = '#FF4444';
          setTimeout(() => { card.style.borderColor = ''; }, 500);
        }
      }
    });
    grid.appendChild(card);
  });
}

function showLeaderboard() {
  gameData = getData();
  const list = document.getElementById('lbList');
  list.innerHTML = '';
  const scores = gameData.scores || [];
  if (scores.length === 0) {
    list.innerHTML = '<div style="color:rgba(255,255,255,0.5);text-align:center;padding:20px;">No scores yet. Play to get on the board!</div>';
  } else {
    const medals = ['🥇','🥈','🥉'];
    scores.forEach((s, i) => {
      const row = document.createElement('div');
      row.className = 'lb-row';
      const d = new Date(s.date);
      row.innerHTML = `<div class="lb-rank">${medals[i]||`#${i+1}`}</div><div class="lb-name">${d.toLocaleDateString()}</div><div class="lb-score">${s.score}</div>`;
      list.appendChild(row);
    });
  }
  showPanel('lbPanel');
}

// ===== INPUT =====
function handleFlap(e) {
  if (e.target.closest('button') || e.target.closest('.skin-card') || e.target.closest('.btn-back')) return;
  if (gameState === 'playing') pendingFlap = true;
}

document.addEventListener('touchstart', handleFlap, { passive: true });
document.addEventListener('mousedown', handleFlap);
document.addEventListener('keydown', (e) => {
  if (e.code === 'Space' || e.code === 'ArrowUp' || e.code === 'KeyW') {
    e.preventDefault();
    if (gameState === 'playing') pendingFlap = true;
  }
  if (e.code === 'Enter' && gameState === 'gameover') startGame();
  if (e.code === 'Escape' && (gameState === 'gameover' || gameState === 'playing')) { triggerGameOver(); showMenu(); }
});
window.addEventListener('keydown', e => { if (e.code === 'Space') e.preventDefault(); });

// ===== BUTTONS =====
document.getElementById('btnPlay').addEventListener('click', e => { e.stopPropagation(); startGame(); });
document.getElementById('btnShop').addEventListener('click', e => { e.stopPropagation(); showShop(); });
document.getElementById('btnLB').addEventListener('click', e => { e.stopPropagation(); showLeaderboard(); });
document.getElementById('btnRestart').addEventListener('click', e => { e.stopPropagation(); startGame(); });
document.getElementById('btnGoMenu').addEventListener('click', e => { e.stopPropagation(); showMenu(); });
document.getElementById('btnShopBack').addEventListener('click', e => { e.stopPropagation(); showMenu(); });
document.getElementById('btnLbBack').addEventListener('click', e => { e.stopPropagation(); showMenu(); });

['btnPlay','btnShop','btnLB','btnRestart','btnGoMenu','btnShopBack','btnLbBack'].forEach(id => {
  const el = document.getElementById(id);
  el.addEventListener('touchend', e => { e.preventDefault(); e.stopPropagation(); el.click(); }, { passive: false });
});

// ===== FULLSCREEN =====
function tryFullscreen() {
  if (!isMobile && document.documentElement.requestFullscreen) {
    document.documentElement.requestFullscreen().catch(() => {});
  }
}
let fullscreenRequested = false;
document.addEventListener('click', () => {
  if (!fullscreenRequested && !isMobile) { fullscreenRequested = true; tryFullscreen(); }
});

document.addEventListener('contextmenu', e => e.preventDefault());

// ===== INIT =====
showMenu();
</script>

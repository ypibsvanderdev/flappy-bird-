<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Flappy Bird Ultra</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html, body {
    width: 100%; height: 100%;
    overflow: hidden;
    background: #000;
    font-family: 'Arial', sans-serif;
    touch-action: none;
  }
  #gameCanvas {
    display: block;
    position: fixed;
    top: 0; left: 0;
  }
  #ui {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    pointer-events: none;
    z-index: 10;
  }
  .panel {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    pointer-events: all;
  }
  .panel.hidden { display: none; }

  #menuPanel {
    background: linear-gradient(180deg, #1a0533 0%, #0d1b4b 50%, #0a2a1a 100%);
  }
  .game-title {
    font-size: clamp(2.5rem, 8vw, 5rem);
    font-weight: 900;
    color: #FFD700;
    text-shadow: 0 0 30px #FFD700, 0 4px 0 #B8860B, 0 6px 0 #8B6914;
    letter-spacing: 2px;
    margin-bottom: 0.3em;
    animation: titlePulse 2s ease-in-out infinite;
  }
  .game-subtitle {
    font-size: clamp(0.8rem, 2.5vw, 1.2rem);
    color: #aef;
    margin-bottom: 2em;
    opacity: 0.9;
  }
  @keyframes titlePulse {
    0%,100%{ transform: scale(1); text-shadow: 0 0 30px #FFD700, 0 4px 0 #B8860B; }
    50%{ transform: scale(1.04); text-shadow: 0 0 60px #FFD700, 0 4px 0 #B8860B; }
  }
  .bird-preview-canvas {
    margin-bottom: 1em;
    filter: drop-shadow(0 0 20px rgba(255,215,0,0.7));
  }
  @keyframes float {
    0%,100%{ transform: translateY(0) rotate(-5deg); }
    50%{ transform: translateY(-20px) rotate(5deg); }
  }
  .btn {
    padding: clamp(12px,3vw,18px) clamp(30px,8vw,60px);
    font-size: clamp(1rem, 3vw, 1.4rem);
    font-weight: 800;
    border: none;
    border-radius: 50px;
    cursor: pointer;
    transition: all 0.15s;
    letter-spacing: 1px;
    pointer-events: all;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
    user-select: none;
  }
  .btn:active { transform: scale(0.95); }
  .btn-play {
    background: linear-gradient(135deg, #FFD700, #FF8C00);
    color: #1a0533;
    box-shadow: 0 8px 30px rgba(255,215,0,0.5);
    margin-bottom: 1rem;
  }
  .btn-play:hover { box-shadow: 0 12px 40px rgba(255,215,0,0.8); transform: translateY(-2px); }
  .btn-shop {
    background: linear-gradient(135deg, #7B2FBE, #4A00E0);
    color: #fff;
    box-shadow: 0 8px 30px rgba(123,47,190,0.5);
    margin-bottom: 1rem;
  }
  .btn-shop:hover { box-shadow: 0 12px 40px rgba(123,47,190,0.8); transform: translateY(-2px); }
  .btn-secondary {
    background: rgba(255,255,255,0.15);
    color: #fff;
    border: 2px solid rgba(255,255,255,0.3);
    backdrop-filter: blur(10px);
    margin-bottom: 0.5rem;
  }
  .stats-bar {
    position: absolute;
    top: 20px;
    display: flex;
    gap: 20px;
    align-items: center;
  }
  .stat-chip {
    background: rgba(0,0,0,0.5);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 20px;
    padding: 8px 16px;
    color: #fff;
    font-size: clamp(0.75rem, 2vw, 1rem);
    font-weight: 700;
    backdrop-filter: blur(10px);
  }
  .stat-chip span { color: #FFD700; }

  #hud {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    z-index: 5;
    pointer-events: none;
    display: none;
  }
  #scoreDisplay {
    position: absolute;
    top: clamp(10px, 3vw, 20px);
    left: 50%;
    transform: translateX(-50%);
    font-size: clamp(2rem, 7vw, 4rem);
    font-weight: 900;
    color: #fff;
    text-shadow: 0 3px 0 rgba(0,0,0,0.5), 0 0 20px rgba(255,255,255,0.3);
    letter-spacing: 2px;
  }
  #powerupDisplay {
    position: absolute;
    top: clamp(10px,3vw,20px);
    right: clamp(10px,3vw,20px);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .powerup-indicator {
    background: rgba(0,0,0,0.6);
    border-radius: 12px;
    padding: 6px 12px;
    color: #fff;
    font-size: clamp(0.7rem, 2vw, 0.9rem);
    font-weight: 700;
    border: 2px solid;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  #livesDisplay {
    position: absolute;
    top: clamp(10px,3vw,20px);
    left: clamp(10px,3vw,20px);
    display: flex;
    gap: 4px;
    font-size: clamp(1.2rem,4vw,1.8rem);
  }
  #tapHint {
    position: absolute;
    bottom: clamp(40px,10vw,80px);
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255,255,255,0.8);
    font-size: clamp(0.8rem,2.5vw,1.1rem);
    font-weight: 600;
    animation: fadeInOut 1.5s ease-in-out infinite;
    white-space: nowrap;
  }
  @keyframes fadeInOut { 0%,100%{opacity:0.4} 50%{opacity:1} }

  #gameOverPanel {
    background: rgba(0,0,0,0.75);
    backdrop-filter: blur(8px);
  }
  .go-title {
    font-size: clamp(2rem,7vw,4rem);
    font-weight: 900;
    color: #FF4444;
    text-shadow: 0 0 30px #FF4444;
    margin-bottom: 0.2em;
  }
  .go-scores {
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 20px;
    padding: clamp(15px,4vw,25px) clamp(25px,6vw,50px);
    margin-bottom: 1.5em;
    text-align: center;
    backdrop-filter: blur(10px);
  }
  .go-score-val {
    font-size: clamp(2.5rem,8vw,5rem);
    font-weight: 900;
    color: #FFD700;
    line-height: 1;
  }
  .go-score-label {
    color: rgba(255,255,255,0.7);
    font-size: clamp(0.75rem,2vw,1rem);
    margin-top: 4px;
  }
  .go-best {
    color: #7eff7e;
    font-size: clamp(0.9rem,2.5vw,1.2rem);
    font-weight: 700;
    margin-top: 8px;
  }

  #shopPanel {
    background: linear-gradient(180deg, #1a0533 0%, #0d1b4b 100%);
    overflow-y: auto;
    justify-content: flex-start;
    padding: clamp(60px,12vw,100px) clamp(15px,4vw,30px) clamp(20px,5vw,40px);
  }
  .shop-title {
    font-size: clamp(1.8rem,5vw,3rem);
    font-weight: 900;
    color: #FFD700;
    margin-bottom: 0.3em;
    text-shadow: 0 0 20px #FFD700;
  }
  .shop-coins {
    font-size: clamp(1rem,3vw,1.4rem);
    color: #FFD700;
    margin-bottom: 1.5em;
    font-weight: 700;
  }
  .shop-section-title {
    color: #aef;
    font-size: clamp(0.9rem,2.5vw,1.2rem);
    font-weight: 700;
    margin-bottom: 1em;
    text-transform: uppercase;
    letter-spacing: 2px;
  }
  .skins-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(clamp(110px,25vw,150px), 1fr));
    gap: clamp(10px,2vw,15px);
    width: 100%;
    max-width: 700px;
    margin-bottom: 2em;
  }
  .skin-card {
    background: rgba(255,255,255,0.07);
    border: 2px solid rgba(255,255,255,0.15);
    border-radius: 16px;
    padding: clamp(12px,3vw,20px) clamp(8px,2vw,15px);
    text-align: center;
    cursor: pointer;
    transition: all 0.2s;
    pointer-events: all;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
  }
  .skin-card:hover { transform: translateY(-4px); border-color: rgba(255,215,0,0.5); }
  .skin-card.selected { border-color: #FFD700; background: rgba(255,215,0,0.15); box-shadow: 0 0 20px rgba(255,215,0,0.3); }
  .skin-card.locked { opacity: 0.6; }
  .skin-canvas { margin-bottom: 8px; display: block; margin-left: auto; margin-right: auto; }
  .skin-name { color: #fff; font-size: clamp(0.7rem,2vw,0.9rem); font-weight: 700; margin-bottom: 4px; }
  .skin-price { color: #FFD700; font-size: clamp(0.65rem,1.8vw,0.85rem); font-weight: 600; }
  .btn-back {
    position: fixed;
    top: clamp(10px,3vw,20px);
    left: clamp(10px,3vw,20px);
    background: rgba(255,255,255,0.15);
    border: 2px solid rgba(255,255,255,0.3);
    color: #fff;
    padding: clamp(8px,2vw,12px) clamp(16px,4vw,24px);
    border-radius: 50px;
    font-size: clamp(0.8rem,2.5vw,1rem);
    font-weight: 700;
    cursor: pointer;
    pointer-events: all;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
    z-index: 100;
  }

  #lbPanel {
    background: linear-gradient(180deg, #0d1b4b 0%, #1a0533 100%);
    overflow-y: auto;
    justify-content: flex-start;
    padding: clamp(60px,12vw,100px) clamp(15px,4vw,30px) clamp(20px,5vw,40px);
  }
  .lb-title {
    font-size: clamp(1.8rem,5vw,3rem);
    font-weight: 900;
    color: #FFD700;
    margin-bottom: 1em;
    text-shadow: 0 0 20px #FFD700;
  }
  .lb-list { width: 100%; max-width: 500px; }
  .lb-row {
    display: flex;
    align-items: center;
    background: rgba(255,255,255,0.07);
    border-radius: 12px;
    padding: clamp(10px,2.5vw,16px) clamp(12px,3vw,20px);
    margin-bottom: 8px;
    border: 1px solid rgba(255,255,255,0.1);
  }
  .lb-rank { color: #FFD700; font-weight: 900; font-size: clamp(1rem,3vw,1.3rem); width: 40px; }
  .lb-name { color: #fff; font-weight: 700; flex: 1; font-size: clamp(0.85rem,2.5vw,1.1rem); }
  .lb-score { color: #aef; font-weight: 900; font-size: clamp(1rem,3vw,1.3rem); }

  #particleCanvas {
    position: fixed;
    top: 0; left: 0;
    pointer-events: none;
    z-index: 4;
  }

  .new-best { animation: newBest 0.5s ease-out; }
  @keyframes newBest {
    0%{ transform: scale(0); }
    70%{ transform: scale(1.2); }
    100%{ transform: scale(1); }
  }
</style>
</head>
<body>

<canvas id="gameCanvas"></canvas>
<canvas id="particleCanvas"></canvas>

<div id="hud">
  <div id="scoreDisplay">0</div>
  <div id="livesDisplay"></div>
  <div id="powerupDisplay"></div>
  <div id="tapHint"></div>
</div>

<div id="ui">
  <!-- MENU -->
  <div class="panel" id="menuPanel">
    <div class="stats-bar">
      <div class="stat-chip">🏆 Best: <span id="menuBest">0</span></div>
      <div class="stat-chip">🪙 <span id="menuCoins">0</span></div>
    </div>
    <canvas id="menuBirdCanvas" class="bird-preview-canvas" width="120" height="120"></canvas>
    <div class="game-title">FLAPPY ULTRA</div>
    <div class="game-subtitle">Tap or Press Space to Flap</div>
    <button class="btn btn-play" id="btnPlay">▶ PLAY</button>
    <button class="btn btn-shop" id="btnShop">🛒 SHOP</button>
    <button class="btn btn-secondary" id="btnLB">🏆 LEADERBOARD</button>
  </div>

  <!-- GAME OVER -->
  <div class="panel hidden" id="gameOverPanel">
    <div class="go-title">GAME OVER</div>
    <div class="go-scores">
      <div class="go-score-val" id="goScore">0</div>
      <div class="go-score-label">SCORE</div>
      <div class="go-best" id="goBest">Best: 0</div>
    </div>
    <button class="btn btn-play" id="btnRestart">▶ PLAY AGAIN</button>
    <button class="btn btn-secondary" id="btnGoMenu" style="margin-top:0.5rem">🏠 MENU</button>
  </div>

  <!-- SHOP -->
  <div class="panel hidden" id="shopPanel">
    <button class="btn-back" id="btnShopBack">← Back</button>
    <div class="shop-title">🛒 SHOP</div>
    <div class="shop-coins">🪙 <span id="shopCoins">0</span> coins</div>
    <div class="shop-section-title">Bird Skins</div>
    <div class="skins-grid" id="skinsGrid"></div>
    <div class="shop-section-title">Power-Ups Info</div>
    <div style="color:rgba(255,255,255,0.7);font-size:clamp(0.7rem,2vw,0.9rem);max-width:500px;text-align:center;line-height:1.6;margin-bottom:2em;">
      ⚡ <b style="color:#FFD700">Speed Boost</b> — Temporary invincibility &amp; speed burst<br>
      🛡️ <b style="color:#00BFFF">Shield</b> — Absorbs one fatal hit<br>
      🐌 <b style="color:#9B59B6">Slow-Mo</b> — Slows pipe speed for 5 seconds<br>
      🧲 <b style="color:#E74C3C">Magnet</b> — Attracts nearby coins<br>
      ❤️ <b style="color:#FF6B9D">Extra Life</b> — Gain one extra life
    </div>
  </div>

  <!-- LEADERBOARD -->
  <div class="panel hidden" id="lbPanel">
    <button class="btn-back" id="btnLbBack">← Back</button>
    <div class="lb-title">🏆 LEADERBOARD</div>
    <div class="lb-list" id="lbList"></div>
  </div>
</div>

<script>
// ===== DEVICE DETECTION =====
const isMobile = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent) || window.innerWidth < 768;

// ===== CANVAS SETUP =====
const canvas = document.getElementById('gameCanvas');
const ctx = canvas.getContext('2d');
const pCanvas = document.getElementById('particleCanvas');
const pCtx = pCanvas.getContext('2d');

function resizeCanvases() {
  canvas.width = window.innerWidth;
  canvas.height = window.innerHeight;
  pCanvas.width = window.innerWidth;
  pCanvas.height = window.innerHeight;
}
resizeCanvases();
window.addEventListener('resize', () => { resizeCanvases(); });

// ===== BIRD SKIN DEFINITIONS =====
// Each skin has: body color, belly color, wing color, beak color, eye color, accent, name, price
const SKINS = [
  { id:'classic',  name:'Classic',  price:0,   body:'#F5D800', belly:'#FFFAAA', wing:'#E5B800', beak:'#FF7700', eye:'#1a1a1a', accent:'#FF4400', tail:'#E5B800' },
  { id:'cool',     name:'Cool',     price:50,  body:'#00BFFF', belly:'#aaeeff', wing:'#0090CC', beak:'#FF6600', eye:'#1a1a1a', accent:'#ffffff', tail:'#0070AA' },
  { id:'fire',     name:'Fire Bird',price:100, body:'#FF4500', belly:'#FFAA00', wing:'#CC2200', beak:'#FFD700', eye:'#1a1a1a', accent:'#FF8800', tail:'#FF2200' },
  { id:'alien',    name:'Alien',    price:150, body:'#00FF88', belly:'#aaffcc', wing:'#00CC66', beak:'#88FF00', eye:'#FF00FF', accent:'#00FFFF', tail:'#00AA55' },
  { id:'robot',    name:'Robot',    price:200, body:'#AAAAAA', belly:'#DDDDDD', wing:'#777777', beak:'#FF4400', eye:'#00FFFF', accent:'#4488FF', tail:'#555555' },
  { id:'dragon',   name:'Dragon',   price:300, body:'#8B0000', belly:'#FF6666', wing:'#660000', beak:'#FFD700', eye:'#FF4500', accent:'#FF8800', tail:'#440000' },
  { id:'unicorn',  name:'Unicorn',  price:400, body:'#FF69B4', belly:'#FFE4F0', wing:'#FF1493', beak:'#FF8C00', eye:'#9400D3', accent:'#FFD700', tail:'#DA70D6' },
  { id:'ghost',    name:'Ghost',    price:250, body:'#E8E8FF', belly:'#ffffff', wing:'#AAAACC', beak:'#9966FF', eye:'#4400AA', accent:'#CC99FF', tail:'#CCCCEE' },
  { id:'skull',    name:'Skull',    price:350, body:'#FFFFFF', belly:'#EEEEEE', wing:'#CCCCCC', beak:'#999999', eye:'#000000', accent:'#FF0000', tail:'#BBBBBB' },
  { id:'rocket',   name:'Rocket',   price:500, body:'#4444FF', belly:'#8888FF', wing:'#2222CC', beak:'#FF4400', eye:'#FFFFFF', accent:'#FF0000', tail:'#1111AA' },
  { id:'diamond',  name:'Diamond',  price:600, body:'#00FFFF', belly:'#AAFFFF', wing:'#00CCCC', beak:'#0088AA', eye:'#003366', accent:'#FFFFFF', tail:'#009999' },
  { id:'crown',    name:'King',     price:750, body:'#FFD700', belly:'#FFF4AA', wing:'#CC9900', beak:'#FF4400', eye:'#1a1a1a', accent:'#AA0000', tail:'#AA7700' },
];

// ===== DRAW BIRD FUNCTION (canvas-based, animated) =====
// wingPhase: 0-1 wing animation, cx/cy: center, size: radius, ctx: context
// flash: boolean for hit flash, shieldActive, invincibleActive
function drawBirdGraphic(context, skin, cx, cy, size, wingPhase, angle, flash, shieldActive, invincibleActive) {
  context.save();
  context.translate(cx, cy);
  if (angle !== undefined) context.rotate(Math.min(Math.max(angle, -0.4), 0.5));

  if (flash) {
    context.globalAlpha = 0.5 + 0.5 * Math.abs(Math.sin(Date.now() * 0.03));
  }

  const s = size;

  // Glow effects
  if (invincibleActive) {
    context.shadowBlur = 30;
    context.shadowColor = '#FFD700';
  } else if (shieldActive) {
    context.shadowBlur = 25;
    context.shadowColor = '#00BFFF';
  } else {
    context.shadowBlur = 12;
    context.shadowColor = skin.body;
  }

  // === TAIL ===
  const tailAngle = -0.3 + Math.sin(wingPhase * Math.PI * 2) * 0.15;
  context.save();
  context.rotate(tailAngle);
  context.fillStyle = skin.tail;
  context.beginPath();
  context.moveTo(-s * 0.5, 0);
  context.lineTo(-s * 1.2, -s * 0.35);
  context.lineTo(-s * 1.35, 0);
  context.lineTo(-s * 1.2, s * 0.35);
  context.closePath();
  context.fill();
  // Tail stripe
  context.fillStyle = skin.accent;
  context.globalAlpha *= 0.5;
  context.beginPath();
  context.moveTo(-s * 0.7, 0);
  context.lineTo(-s * 1.2, -s * 0.18);
  context.lineTo(-s * 1.35, 0);
  context.lineTo(-s * 1.2, s * 0.18);
  context.closePath();
  context.fill();
  context.globalAlpha = flash ? (0.5 + 0.5 * Math.abs(Math.sin(Date.now() * 0.03))) : 1;
  context.restore();

  // === WING (animated) ===
  const wingFlap = Math.sin(wingPhase * Math.PI * 2);
  const wingY = wingFlap * s * 0.55;
  const wingScaleY = 0.7 + Math.abs(wingFlap) * 0.5;

  context.save();
  context.shadowBlur = 6;
  context.shadowColor = skin.wing;
  // Wing gradient
  const wingGrad = context.createRadialGradient(-s*0.1, wingY - s*0.1, 0, -s*0.1, wingY, s*0.85);
  wingGrad.addColorStop(0, skin.wing);
  wingGrad.addColorStop(1, skin.tail);
  context.fillStyle = wingGrad;
  context.beginPath();
  context.ellipse(-s * 0.1, wingY, s * 0.75, s * 0.32 * wingScaleY, -0.2, 0, Math.PI * 2);
  context.fill();
  // Wing highlight
  context.fillStyle = 'rgba(255,255,255,0.25)';
  context.beginPath();
  context.ellipse(-s * 0.1, wingY - s*0.06, s * 0.4, s * 0.12 * wingScaleY, -0.2, 0, Math.PI * 2);
  context.fill();
  context.restore();

  // === BODY ===
  const bodyGrad = context.createRadialGradient(s*0.1, -s*0.1, s*0.1, 0, 0, s);
  bodyGrad.addColorStop(0, lightenHex(skin.body, 60));
  bodyGrad.addColorStop(0.5, skin.body);
  bodyGrad.addColorStop(1, darkenHex(skin.body, 40));
  context.fillStyle = bodyGrad;
  context.beginPath();
  context.ellipse(0, 0, s, s * 0.82, 0, 0, Math.PI * 2);
  context.fill();

  // === BELLY ===
  const bellyGrad = context.createRadialGradient(s*0.15, s*0.1, 0, s*0.15, s*0.15, s*0.55);
  bellyGrad.addColorStop(0, skin.belly);
  bellyGrad.addColorStop(1, skin.body);
  context.fillStyle = bellyGrad;
  context.beginPath();
  context.ellipse(s * 0.15, s * 0.15, s * 0.5, s * 0.4, 0.2, 0, Math.PI * 2);
  context.fill();

  // === BODY OUTLINE ===
  context.shadowBlur = 0;
  context.strokeStyle = darkenHex(skin.body, 60);
  context.lineWidth = s * 0.06;
  context.beginPath();
  context.ellipse(0, 0, s, s * 0.82, 0, 0, Math.PI * 2);
  context.stroke();

  // === BEAK ===
  context.shadowBlur = 4;
  context.shadowColor = '#00000066';
  const beakGrad = context.createLinearGradient(s*0.5, -s*0.12, s*0.5, s*0.12);
  beakGrad.addColorStop(0, lightenHex(skin.beak, 40));
  beakGrad.addColorStop(1, darkenHex(skin.beak, 20));
  context.fillStyle = beakGrad;
  // Upper beak
  context.beginPath();
  context.moveTo(s * 0.48, -s * 0.08);
  context.lineTo(s * 1.05, -s * 0.04);
  context.lineTo(s * 0.85, s * 0.06);
  context.lineTo(s * 0.48, s * 0.02);
  context.closePath();
  context.fill();
  context.strokeStyle = darkenHex(skin.beak, 40);
  context.lineWidth = s * 0.04;
  context.stroke();
  // Lower beak
  context.fillStyle = darkenHex(skin.beak, 15);
  context.beginPath();
  context.moveTo(s * 0.48, s * 0.02);
  context.lineTo(s * 0.85, s * 0.06);
  context.lineTo(s * 0.75, s * 0.18);
  context.lineTo(s * 0.48, s * 0.14);
  context.closePath();
  context.fill();

  // === EYE ===
  context.shadowBlur = 0;
  // Eye white
  context.fillStyle = '#FFFFFF';
  context.beginPath();
  context.ellipse(s * 0.28, -s * 0.2, s * 0.22, s * 0.22, 0, 0, Math.PI * 2);
  context.fill();
  // Iris
  const irisColor = skin.eye === '#1a1a1a' ? '#3a2a00' : skin.eye;
  context.fillStyle = irisColor;
  context.beginPath();
  context.ellipse(s * 0.32, -s * 0.2, s * 0.14, s * 0.14, 0, 0, Math.PI * 2);
  context.fill();
  // Pupil
  context.fillStyle = '#000000';
  context.beginPath();
  context.ellipse(s * 0.34, -s * 0.21, s * 0.07, s * 0.07, 0, 0, Math.PI * 2);
  context.fill();
  // Eye shine 1
  context.fillStyle = 'rgba(255,255,255,0.95)';
  context.beginPath();
  context.ellipse(s * 0.29, -s * 0.26, s * 0.05, s * 0.05, 0, 0, Math.PI * 2);
  context.fill();
  // Eye shine 2
  context.fillStyle = 'rgba(255,255,255,0.6)';
  context.beginPath();
  context.ellipse(s * 0.38, -s * 0.16, s * 0.025, s * 0.025, 0, 0, Math.PI * 2);
  context.fill();
  // Eye outline
  context.strokeStyle = darkenHex(skin.body, 60);
  context.lineWidth = s * 0.04;
  context.beginPath();
  context.ellipse(s * 0.28, -s * 0.2, s * 0.22, s * 0.22, 0, 0, Math.PI * 2);
  context.stroke();

  // === HEAD FEATHERS ===
  context.fillStyle = skin.accent;
  context.shadowBlur = 3;
  context.shadowColor = skin.accent;
  for (let i = 0; i < 3; i++) {
    const fx = -s*0.1 + i * s*0.2;
    const fy = -s * 0.82;
    const fh = s * (0.28 - i * 0.04);
    const fw = s * 0.12;
    const fAngle = -0.3 + i * 0.2 + Math.sin(wingPhase * Math.PI * 2 + i) * 0.1;
    context.save();
    context.translate(fx, fy);
    context.rotate(fAngle);
    context.beginPath();
    context.ellipse(0, -fh/2, fw, fh, 0, 0, Math.PI * 2);
    context.fill();
    context.restore();
  }

  // === CHEEK BLUSH ===
  context.shadowBlur = 0;
  context.fillStyle = 'rgba(255,100,100,0.3)';
  context.beginPath();
  context.ellipse(s * 0.35, s * 0.05, s * 0.18, s * 0.1, 0, 0, Math.PI * 2);
  context.fill();

  // === SHIELD RING ===
  if (shieldActive) {
    context.shadowBlur = 20;
    context.shadowColor = '#00BFFF';
    context.strokeStyle = '#00BFFF';
    context.lineWidth = s * 0.08;
    context.beginPath();
    context.arc(0, 0, s * 1.4, 0, Math.PI * 2);
    context.stroke();
    context.strokeStyle = 'rgba(0,191,255,0.3)';
    context.lineWidth = s * 0.2;
    context.beginPath();
    context.arc(0, 0, s * 1.5, 0, Math.PI * 2);
    context.stroke();
  }

  context.restore();
}

// Color helpers
function lightenHex(hex, amount) {
  if (hex.startsWith('#')) {
    let r = parseInt(hex.slice(1,3),16);
    let g = parseInt(hex.slice(3,5),16);
    let b = parseInt(hex.slice(5,7),16);
    r = Math.min(255, r + amount);
    g = Math.min(255, g + amount);
    b = Math.min(255, b + amount);
    return `#${r.toString(16).padStart(2,'0')}${g.toString(16).padStart(2,'0')}${b.toString(16).padStart(2,'0')}`;
  }
  return hex;
}
function darkenHex(hex, amount) {
  if (hex.startsWith('#')) {
    let r = parseInt(hex.slice(1,3),16);
    let g = parseInt(hex.slice(3,5),16);
    let b = parseInt(hex.slice(5,7),16);
    r = Math.max(0, r - amount);
    g = Math.max(0, g - amount);
    b = Math.max(0, b - amount);
    return `#${r.toString(16).padStart(2,'0')}${g.toString(16).padStart(2,'0')}${b.toString(16).padStart(2,'0')}`;
  }
  return hex;
}

// ===== DATA =====
function loadData() {
  try { return JSON.parse(localStorage.getItem('flappyUltraData') || '{}'); }
  catch(e) { return {}; }
}
function saveData(d) { localStorage.setItem('flappyUltraData', JSON.stringify(d)); }
function getData() {
  const d = loadData();
